---
import Section from "@/components/Section.astro"
import { formatCvDate } from "@/i18n/formatCvDate"
import { cvLabels } from "@/i18n/ui"

interface Education {
  institution: string
  startDate: string
  endDate: string | null
  area: string
  studyType: string
}

const education: Education[] = Astro.props.cv.education
const currentLanguage = (Astro.currentLocale ?? "en") as "en" | "es"
const labels = cvLabels[currentLanguage]
---

<Section title="education">
  <ul>
    {
      education.map(({ institution, startDate, endDate, area, studyType }) => {
        const start = formatCvDate(startDate, currentLanguage)
        const end = endDate
          ? formatCvDate(endDate, currentLanguage)
          : labels.present
        const dates = `${start} - ${end}`
        const degree = studyType
          ? `${studyType} ${labels.educationIn} ${area}`
          : area

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                <time>{dates}</time>
              </header>

              <footer>
                <p>{degree}</p>
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-heading);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    min-width: 145px;
    white-space: nowrap;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }

  @media (width <= 420px) {
    header {
      flex-direction: column;
      gap: 4px;
    }

    time {
      min-width: 0;
      text-align: left;
    }
  }
</style>
