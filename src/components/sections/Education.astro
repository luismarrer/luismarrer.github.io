---
import Section from "@/components/Section.astro"
import { formatCvDate } from "@/i18n/formatCvDate"
import { cvLabels } from "@/i18n/ui"

interface Education {
  institution: string
  startDate: string
  endDate: string | null
  area: string
  studyType: string
  url: string
}

const education: Education[] = Astro.props.cv.education
const currentLanguage = (Astro.currentLocale ?? "en") as "en" | "es"
const labels = cvLabels[currentLanguage]
---

<Section title="education">
  <ul>
    {
      education.map(
        ({ institution, startDate, endDate, area, studyType, url }) => {
          const start = formatCvDate(startDate, currentLanguage)
          const end = endDate
            ? formatCvDate(endDate, currentLanguage)
            : labels.present
          const dates = `${start} - ${end}`
          const degree = studyType
            ? `${studyType} ${labels.educationIn} ${area}`
            : area

          return (
            <li>
              <article data-print-item="education">
                <header>
                  <div>
                    <h3>
                      <a
                        href={url}
                        title={institution}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {institution}
                      </a>
                    </h3>
                  </div>

                  <time>{dates}</time>
                </header>

                <footer>
                  <p>{degree}</p>
                </footer>
              </article>
            </li>
          )
        },
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-heading);
  }

  article a {
    color: var(--text-heading);
  }

  article a:hover {
    text-decoration: underline;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    min-width: 145px;
    white-space: nowrap;
  }

  @media screen and (width <= 700px) {
    time {
      text-align: right;
    }
  }

  @media screen and (width <= 420px) {
    header {
      flex-direction: column;
      gap: 4px;
    }

    time {
      min-width: 0;
      text-align: left;
    }
  }

  @media print {
    ul {
      display: block;
    }

    li + li {
      margin-top: 10pt;
    }

    article {
      break-inside: avoid-page;
      page-break-inside: avoid;
    }

    article h3 {
      font-size: 10.25pt;
      line-height: 1.2;
    }

    article footer p {
      font-size: 8.75pt;
      line-height: 1.3;
    }

    header {
      margin-bottom: 1.5pt;
    }

    time {
      min-width: 118pt;
      font-size: 8.25pt;
      line-height: 1.3;
      text-align: right;
    }
  }
</style>
