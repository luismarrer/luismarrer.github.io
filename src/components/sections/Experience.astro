---
import Section from "@/components/Section.astro"
import { formatCvDate } from "@/i18n/formatCvDate"
import { cvLabels } from "@/i18n/ui"

interface WorkExperience {
  name: string
  startDate: string
  endDate: string | null
  position: string
  summary: string
  url: string
}

const { work }: { work: WorkExperience[] } = Astro.props.cv
const currentLanguage = (Astro.currentLocale ?? "en") as "en" | "es"
const labels = cvLabels[currentLanguage]
---

<Section title="experience">
  <ul>
    {
      work.map(({ name, startDate, endDate, position, summary, url }) => {
        const start = formatCvDate(startDate, currentLanguage)
        const end = endDate
          ? formatCvDate(endDate, currentLanguage)
          : labels.present
        const dates = `${start} - ${end}`
        return (
          <li>
            <article data-print-item="experience">
              <header>
                <div>
                  <h3>
                    <a
                      href={url}
                      title={name}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {name}
                    </a>
                  </h3>
                  <p>{position}</p>
                </div>
                <time>{dates}</time>
              </header>
              <footer>
                <p>{summary}</p>
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-heading);
  }

  article a {
    color: var(--text-heading);
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: var(--text-heading);
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    min-width: 145px;
    white-space: nowrap;
    cursor: default;
  }

  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: #333;
    color: #fff;
    font-size: 0.75rem;
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      monospace;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 1px 1px 1px #222222;
    opacity: 0;
    border: 1px solid #111111;
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media screen and (width <= 700px) {
    time {
      text-align: right;
    }
  }

  @media screen and (width <= 420px) {
    header {
      flex-direction: column;
      gap: 4px;
    }

    time {
      min-width: 0;
      text-align: left;
    }
  }

  @media print {
    ul {
      display: block;
    }

    li + li {
      margin-top: 14pt;
    }

    article {
      break-inside: avoid-page;
      page-break-inside: avoid;
    }

    article h3 {
      font-size: 10.5pt;
      line-height: 1.2;
    }

    article header p,
    article footer p {
      font-size: 9pt;
      line-height: 1.38;
    }

    header {
      margin-bottom: 2pt;
    }

    time {
      min-width: 118pt;
      font-size: 8.25pt;
      line-height: 1.35;
      text-align: right;
    }
  }
</style>
