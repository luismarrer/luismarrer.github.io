---
import GitHub from "@/icons/GitHub.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import Mail from "@/icons/Mail.astro"
import Phone from "@/icons/Phone.astro"
import Pin from "@/icons/Pin.astro"
import Section from "@/components/Section.astro"
import WorldMap from "@/icons/WorldMap.astro"
import X from "@/icons/X.astro"
import type { Icon } from "@/types"

const basics = Astro.props.cv.basics

const { name, label, image, email, phone, url, location, profiles } = basics
const { city, region } = location
const SOCIAL_NETWORKS_ICONS: Icon = {
  GitHub,
  LinkedIn,
  X,
}

interface Profile {
  network: string
  url: string
}

const linkedInfo = profiles.find(
  ({ network }: Profile) => network === "LinkedIn",
)
const linkedUrl = linkedInfo?.url
const compactUrl = (value?: string) =>
  value?.replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "")
const websiteLabel = compactUrl(url)
const linkedLabel = compactUrl(linkedUrl)
const phoneLabel = phone?.replace(
  /^\+1(\d{3})(\d{3})(\d{4})$/,
  "+1 $1 $2 $3",
)
---

<Section>
  <div class="hero">
    <div class="info">
      <h1>{name}</h1>
      <p>{label}</p>
      <p>
        <a
          id="location"
          href="https://www.google.com/maps/place/San+Juan"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Pin />
          {city}, {region}
        </a>
      </p>
      <footer class="print print-contacts">
        {
          email && (
            <a data-print-contact="email" href={`mailto:${email}`}>
              {email}
            </a>
          )
        }
        {
          phone && (
            <a data-print-contact="phone" href={`tel:${phone}`}>
              {phoneLabel}
            </a>
          )
        }
        {
          url && (
            <a
              data-print-contact="website"
              href={url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {websiteLabel}
            </a>
          )
        }
        {
          linkedUrl && (
            <a
              data-print-contact="linkedin"
              href={linkedUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              {linkedLabel}
            </a>
          )
        }
      </footer>
      <footer class="no-print">
        {
          url && (
            <a
              href={url}
              title="Website"
              target="_blank"
              rel="noopener noreferrer"
            >
              <WorldMap />
            </a>
          )
        }
        {
          email && (
            <a
              href={`mailto:${email}`}
              title={`Email: ${email}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
            </a>
          )
        }
        {
          phone && (
            <a
              href={`tel:${phone}`}
              title={`Phone: ${phone}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Phone />
            </a>
          )
        }
        {
          profiles.map(({ network, url }: Profile) => {
            const Icon = SOCIAL_NETWORKS_ICONS[network]
            return (
              <a
                href={url}
                title={`${network}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
              </a>
            )
          })
        }
      </footer>
    </div>
    <figure>
      <img src={image} alt={name} />
    </figure>
  </div>

  <style>
    .hero {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .info {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 0;
      padding-right: 32px;
    }

    figure {
      flex: 0 0 auto;
    }

    h1 {
      font-size: 2rem;
    }

    p {
      color: var(--text-body);
      font-weight: 500;
      font-size: 1.1rem;
      text-wrap: balance;
    }

    img {
      aspect-ratio: 1 / 1;
      object-fit: cover;
      display: block;
      width: 128px;
      border-radius: 16px;
    }

    #location {
      color: var(--text-body);
      font-size: 0.85rem;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      letter-spacing: -0.05rem;
    }

    #location:hover {
      text-decoration: underline;
    }

    footer {
      color: var(--text-muted);
      font-size: 0.75rem;
      display: flex;
      gap: 4px;
      margin-top: 8px;
    }

    .no-print a {
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border);
      padding: 4px;
      height: 32px;
      width: 32px;
      border-radius: 6px;
      transition:
        background 0.3s,
        ease;
    }

    .no-print a:hover {
      background: var(--surface);
      border: 1px solid var(--border-hover);
    }

    @media screen and (max-width: 768px) {
      .info {
        padding-right: 0;
      }

      h1 {
        letter-spacing: -0.1rem;
      }

      img {
        width: 96px;
      }
    }

    @media screen and (max-width: 480px) {
      .hero {
        flex-direction: column;
        justify-content: flex-start;
        gap: 16px;
      }

      .info {
        align-items: center;
        text-align: center;
        gap: 8px;
      }

      figure {
        order: -1;
      }

      h1 {
        font-size: 1.9rem;
        line-height: 1.1;
        max-width: 340px;
      }

      .info > p {
        max-width: 320px;
      }

      img {
        width: 112px;
      }

      footer {
        justify-content: center;
      }
    }

    @media screen and (max-width: 360px) {
      .hero {
        gap: 14px;
      }

      img {
        width: 104px;
      }
    }

    @media print {
      .hero {
        display: block;
        padding-bottom: 12pt;
        border-bottom: 0.75pt solid #b8b8b8;
      }

      .info {
        gap: 2.5pt;
        padding-right: 0;
      }

      h1 {
        font-size: 22pt;
        line-height: 1.05;
        letter-spacing: -0.45pt;
      }

      .info > p {
        font-size: 10pt;
        line-height: 1.25;
      }

      #location {
        font-size: 8.75pt;
        letter-spacing: 0;
      }

      figure {
        display: none;
      }

      footer.print-contacts {
        display: flex !important;
        flex-wrap: wrap;
        align-items: center;
        gap: 2pt 0;
        margin-top: 4pt;
        font-size: 8.25pt;
        line-height: 1.25;
      }

      .print-contacts a {
        color: #111 !important;
        text-decoration: underline;
        text-decoration-color: #aaa;
        text-underline-offset: 1.5pt;
      }

      .print-contacts a + a::before {
        content: "\2022";
        display: inline-block;
        margin: 0 5pt;
        color: #777;
        text-decoration: none;
      }
    }
  </style>
</Section>
