---
import GitHub from "@/icons/GitHub.astro"
import Section from "@/components/Section.astro"

interface Project {
  urls: {
    website: string
    gitHub?: string
  }
  description: string
  highlights: string[]
  name: string
  endDate?: string
  startDate?: string
}

const projects: Project[] = Astro.props.cv.projects
---

<Section title="projects">
  <ul id="projects">
    {
      projects.map(
        ({ urls, description, highlights, name, endDate, startDate }) => {
          const isActive = startDate && !endDate
          return (
            <li>
              <article data-print-item="project">
                <header>
                  <h3>
                    <a
                      href={urls.website}
                      title={`Project ${name}`}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {name}
                    </a>
                    {isActive && <span>&bull;</span>}
                    {urls.gitHub && (
                      <a
                        class="github-code-link"
                        href={urls.gitHub}
                        target="_blank"
                        rel="noopener noreferrer"
                        title={`Project code - ${name}`}
                      >
                        <GitHub />
                      </a>
                    )}
                  </h3>
                  <p>{description}</p>
                </header>
                <footer>
                  <ul class="highlights">
                    {highlights.map((highlight) => {
                      return <li>{highlight}</li>
                    })}
                  </ul>
                </footer>
              </article>
            </li>
          )
        },
      )
    }
  </ul>
</Section>
<style>
  #projects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  article {
    border-radius: 8px;
    border: 1px solid var(--card-border);
    gap: 16px;
    display: flex;
    flex-direction: column;
    padding: 16px;
    height: 100%;
    min-height: 191.56px;
  }

  article header {
    flex: 1;
  }

  article h3 {
    margin-bottom: 4px;
    font-weight: normal;
    font-size: 1rem;
  }

  article a {
    color: var(--text-heading);
  }

  article a:hover {
    text-decoration: underline;
  }

  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 4px;
  }

  article h3 span {
    color: rgb(0, 188, 47);
    animation-name: flicker;
    animation-duration: 3s;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }

  .github-code-link {
    margin-left: 5px;
  }

  footer ul {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }

  footer li {
    border-radius: 6px;
    background: var(--surface);
    color: var(--tag-text);
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
  }

  @keyframes flicker {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.25;
    }
    100% {
      opacity: 1;
    }
  }

  @media screen and (width <= 700px) {
    #projects {
      gap: 20px;
      margin-inline: 0px;
    }

    article {
      border: 1px solid var(--card-border);
      border-radius: 12px;
      box-shadow: none;
      gap: 18px;
      height: auto;
      min-height: 0;
      padding: 20px;
    }

    article h3 {
      font-size: 1.1rem;
      margin-bottom: 8px;
    }

    article p {
      font-size: 0.85rem;
      line-height: 1.35rem;
      margin-bottom: 0;
    }

    footer ul {
      gap: 6px;
    }

    footer li {
      font-size: 0.7rem;
      padding: 0.3rem 0.65rem;
    }
  }

  @media print {
    #projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 9pt;
    }

    article {
      height: auto;
      min-height: 0;
      gap: 7pt;
      padding: 9pt 10pt;
      border: 0.5pt solid #aaa;
      border-radius: 3pt;
      break-inside: avoid-page;
      page-break-inside: avoid;
    }

    article h3 {
      margin-bottom: 3pt;
      font-size: 10.25pt;
      line-height: 1.2;
    }

    article p {
      margin-bottom: 0;
      font-size: 8.5pt;
      line-height: 1.35;
    }

    article h3 span {
      animation-name: none;
      color: #555;
    }

    footer ul {
      gap: 3pt;
    }

    footer li {
      padding: 1.5pt 4pt;
      border: 0.5pt solid #bbb;
      border-radius: 2pt;
      background: transparent;
      color: #222;
      font-size: 7.25pt;
      line-height: 1.2;
    }
  }
</style>
