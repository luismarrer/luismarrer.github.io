---
import { theme } from "@/i18n/ui"
const currentLanguage = Astro.currentLocale ?? "en"
const basics = Astro.props.cv.basics
const themeToggleLabel =
  theme[currentLanguage as keyof typeof theme]?.toggle ?? theme.en.toggle
interface Props {
  title: string
  cv: {
    basics: {
      image: string
      summary: string
      url: string
    }
  }
}
const { title } = Astro.props
const { image, summary, url } = basics
---

<!doctype html>
<html lang={currentLanguage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ""} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content="" />
    <meta
      name="google-site-verification"
      content="hANEyjHty5BYTdBG_zYI4VlUuvBw8xHq6O29I-XK0GI"
    />
    <script is:inline>
      const storedTheme = localStorage.getItem("theme")
      document.documentElement.dataset.theme =
        storedTheme ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light")
    </script>
  </head>
  <body>
    <button id="theme-toggle" class="no-print" aria-label={themeToggleLabel}>
      <svg
        class="sun"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
      <svg
        class="moon"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </svg>
    </button>
    <slot />
    <script>
      import { toggleTheme } from "@/lib/theme"

      document
        .getElementById("theme-toggle")
        ?.addEventListener("click", () => toggleTheme())
    </script>
  </body>
</html>

<style is:global>
  html {
    color-scheme: light;
    --bg: #fff;
    --text-heading: #111;
    --text-body: #666;
    --text-muted: #555;
    --border: #eee;
    --border-hover: #ddd;
    --surface: #eee;
    --tag-text: #444;
    --card-border: #f2f2f2;
    --footer-bg: #fdfdfd;
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --bg: #121212;
    --text-heading: #ededed;
    --text-body: #a1a1aa;
    --text-muted: #8f8f96;
    --border: #2e2e2e;
    --border-hover: #3f3f46;
    --surface: #27272a;
    --tag-text: #d4d4d8;
    --card-border: #232323;
    --footer-bg: #161616;
  }

  html {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background: var(--bg);
    letter-spacing: -0.025rem;
  }

  /* Reset */
  body,
  figure {
    margin: 0;
    padding: 0;
  }

  body {
    color: var(--text-heading);
  }

  a {
    color: var(--text-body);
    text-decoration: none;
    display: inline-flex;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: var(--text-body);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  #theme-toggle {
    position: fixed;
    top: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 4px;
    background: var(--bg);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    z-index: 10;
    transition: background 0.3s;
  }

  #theme-toggle:hover {
    background: var(--surface);
    border-color: var(--border-hover);
  }

  #theme-toggle .moon,
  html[data-theme="dark"] #theme-toggle .sun {
    display: block;
  }

  #theme-toggle .sun,
  html[data-theme="dark"] #theme-toggle .moon {
    display: none;
  }

  .print {
    display: none !important;
  }

  @page {
    size: letter portrait;
    margin: 0.48in 0.52in;
  }

  @media print {
    html,
    html[data-theme="dark"] {
      color-scheme: light;
      --bg: #fff;
      --text-heading: #111;
      --text-body: #2f2f2f;
      --text-muted: #444;
      --border: #aaa;
      --border-hover: #888;
      --surface: #fff;
      --tag-text: #222;
      --card-border: #aaa;
      --footer-bg: #fff;
      background: #fff;
      font-size: 10pt;
      letter-spacing: -0.1pt;
    }

    body {
      margin: 0;
      background: #fff;
      color: #111;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    main {
      width: auto !important;
      max-width: none !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .print {
      display: block !important;
    }

    a {
      color: #111 !important;
    }

    p {
      orphans: 3;
      widows: 3;
    }

    .no-print {
      display: none !important;
    }
  }
</style>
